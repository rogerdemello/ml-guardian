# ML Guardian configuration (copy to .env and edit)

# DataHub integration mode: "fixture" (offline, default) or "mcp" (live DataHub via mcp-server-datahub)
DATAHUB_MODE=fixture

# --- Only needed when DATAHUB_MODE=mcp ---
# DataHub GMS / MCP endpoint and a personal access token.
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_TOKEN=
# Base URL used to build clickable links to the DataHub UI from the dashboard.
DATAHUB_UI_URL=http://localhost:9002

# --- Optional LLM (agent orchestration + remediation codegen): Google Gemini ---
# If unset, ML Guardian falls back to deterministic templates and still runs end-to-end.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Storage ---
DATABASE_URL=sqlite:///./ml_guardian.db

# --- Risk detection thresholds ---
# Freshness SLA breach (hours over expected) and quality null-rate ceiling.
FRESHNESS_WARN_RATIO=1.0
QUALITY_NULL_RATE_MAX=0.05
